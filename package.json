{
  "name": "devfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx @opennextjs/cloudflare build",
    "start": "next start",
    "lint": "next lint",
    "cf:build": "npx @opennextjs/cloudflare build",
    "cf:deploy": "npm run cf:build && wrangler deploy",
    "cf:preview": "npm run cf:build && wrangler dev",
    "db:create": "wrangler d1 create devfolio-db",
    "db:migrate": "wrangler d1 execute devfolio-db --file=./migrations/0001_schema.sql",
    "db:migrate:local": "wrangler d1 execute devfolio-db --local --file=./migrations/0001_schema.sql"
  },
  "dependencies": {
    "next": "^15.5.15",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260329.1",
    "@opennextjs/cloudflare": "^1.18.1",
    "esbuild": "^0.27.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wrangler": "^4.78.0"
  }
}
